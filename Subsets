https://leetcode.com/problems/subsets/description/

class Solution {
    public List<List<Integer>> subsets(int[] nums) {
        List<List<Integer>> ans = new ArrayList<>();
        List<Integer> ar = new ArrayList<>();
        Backtrack(nums,0,ar,ans);
        return ans;
    }
    public static void Backtrack(int[] nums,int idx, List<Integer> ar,List<List<Integer>> ans){
          if(idx == nums.length){
            ans.add(new ArrayList<>(ar));
            return;
          }
        ar.add(nums[idx]);
        Backtrack(nums,idx+1,ar,ans);

        ar.remove(ar.size()-1);
        Backtrack(nums,idx+1,ar,ans);        
        



          }
    } 
